# Tailscale API credentials
TAILSCALE_API_KEY=tskey-api-xxxxx
# TAILSCALE_TAILNET=-              # Optional: tailnet name or "-" for auto-detect (default)

# Write operations (disabled by default)
# TAILSCALE_WRITE_ENABLED=true

# HTTP transport (optional, default is stdio)
# TAILSCALE_MCP_TRANSPORT=http
# TAILSCALE_MCP_HOST=127.0.0.1
# TAILSCALE_MCP_PORT=8782
# TAILSCALE_MCP_API_TOKEN=your-bearer-token

# Logging
# TAILSCALE_LOG_LEVEL=WARNING
